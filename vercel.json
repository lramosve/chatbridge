{
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "release/app/dist/renderer",
  "installCommand": "pnpm install --ignore-scripts",
  "framework": null,
  "rewrites": [
    { "source": "/plugins/(.*)", "destination": "/plugins/$1" },
    { "source": "/((?!plugins/).*)", "destination": "/index.html" }
  ]
}
